# Copy to `.env` for local Vite. Keys must be prefixed with VITE_ to be exposed to the client.

# Maps JavaScript API key (browser). Enable APIs below in Google Cloud for this key.
# Application restriction: HTTP referrers (e.g. http://localhost:5174/* and your production origin).
# API restriction: enable at least "Maps JavaScript API" and "Directions API" (required for route lines).
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_browser_key_here

# Optional: show on-screen Maps diagnostics (?mapsDebug=1 also works)
# VITE_MAPS_DEBUG=true
