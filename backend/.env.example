# Copy to `.env` and adjust for your machine.

NODE_ENV=development
PORT=8000

# Development (SQLite) — path to sqlite file
DB_FILE=db/dev.sqlite

# Production — PostgreSQL connection string (used when NODE_ENV=production)
# DATABASE_URL=postgres://user:pass@host:5432/dineair
# SCHEMA=public

# JWT session cookie
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=604800

# Google Maps (Directions API for server-side ETA). Prefer a server key; frontend key works for local dev.
# GOOGLE_MAPS_API_KEY=
# VITE_GOOGLE_MAPS_API_KEY=

# Comma-separated Socket.IO + Express CORS allowed origins (defaults include localhost 5173–5175 and dineair.onrender.com)
# FRONTEND_URLS=http://localhost:5175,http://127.0.0.1:5175,https://your-frontend.onrender.com

# When the SPA and API are on different sites, set to none so the browser sends the JWT cookie on credentialed fetches/sockets.
# Requires HTTPS. Leave unset for same-origin or typical single-service deploys.
# TOKEN_COOKIE_SAMESITE=none

# Render build command: npm run render-build (builds frontend + backend, runs migrations).
# Migrations run automatically on every deploy. Seeding does not (it is not safe to
# re-run on top of existing data) — run once via Render's shell after the first deploy:
#   npm run db:deploy --prefix backend
# The demo seeders reference hardcoded row IDs (e.g. Cart.userId: 1) and are NOT safe to
# undo-then-reseed against a database that already has other rows in it — SQLite/Postgres
# don't reset auto-increment counters on DELETE, so a reseed after `db:seed:undo` can insert
# users at IDs the other seeders don't expect and fail with a foreign key error. To fully
# reset demo data, start from an empty database instead: for local SQLite dev, delete the
# file at DB_FILE and re-run `db:migrate` + `db:seed`; for Postgres, provision a fresh
# database (or truncate every table in FK-safe order) before reseeding.
